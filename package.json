{
  "name": "tier-list-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "lsof -tiTCP:5810 -sTCP:LISTEN | xargs kill 2>/dev/null; pnpm --filter @tier-list/client dev",
    "server": "lsof -tiTCP:5811 -sTCP:LISTEN | xargs kill 2>/dev/null; pnpm --filter @tier-list/server dev",
    "dev:all": "lsof -tiTCP:5810,5811 -sTCP:LISTEN | xargs kill 2>/dev/null; concurrently -k -n web,server -c blue,green \"pnpm --filter @tier-list/client dev\" \"pnpm --filter @tier-list/server dev\"",
    "kill-ports": "lsof -tiTCP:5810,5811 -sTCP:LISTEN | xargs kill 2>/dev/null || true",
    "build": "pnpm --filter @tier-list/client build",
    "preview": "pnpm --filter @tier-list/client preview",
    "lint": "eslint ."
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "better-sqlite3"]
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.30.1"
  }
}
