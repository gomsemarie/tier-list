# Naver Open API — image search proxy (server-side only, NOT exposed to the browser).
# These are read by the Vite dev middleware (/api/naver-image); they are never
# bundled into client code because they are not prefixed with VITE_.
#
# Setup:
#   1. Go to https://developers.naver.com/apps and register an application.
#   2. Add the "검색" (Search) API to the app.
#   3. Copy the Client ID / Client Secret below.
#   4. Copy this file to `.env.local` and fill in the values, then restart `pnpm dev`.
#
# Without these, image search falls back to the keyless chain (Wikipedia → Openverse).
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Dev server port (default 5810). Change here if it collides with another project.
# VITE_PORT=5810

# Realtime server URL the client connects to (default http://localhost:5811).
# If you change the server's PORT, update this to match.
# VITE_SERVER_URL=http://localhost:5811
