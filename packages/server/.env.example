# Copy to .env and edit. Loaded automatically by the server on startup.

# Admin accounts (comma-separated login ids). Always admins, locked (cannot be
# demoted in-app). Example: ADMIN_USERNAMES=gomsemarie,anotherAdmin
ADMIN_USERNAMES=

# Optional: seed a new admin account on first run (only if it doesn't exist).
# ADMIN_USERNAME=
# ADMIN_PASSWORD=

# Optional overrides
# PORT=5811
# DB_PATH=data/rooms.db
